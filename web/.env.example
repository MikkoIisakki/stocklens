# Pulse web shell — copy to .env.local and fill in.
#
# PULSE_DOMAIN selects which config/domains/<name>.yaml the build reads.
# Different deployments (one per branded app) set this to a different value.
PULSE_DOMAIN=energy

# Backend base URL the server components fetch from. Server-side only.
PULSE_API_BASE_URL=http://localhost:8000

# API key for the backend (Authorization: Bearer ...). Server-side only —
# never exposed to the browser. In production, issue per-deployment via:
#     docker compose exec api python -m app.tools.create_api_key --name pulse-web-prod
PULSE_API_KEY=
