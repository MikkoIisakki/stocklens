# Pulse mobile shell — copy to .env and source it before `expo start`,
# or rely on EAS build profiles to set these per environment.
#
# Build-time only. The `EXPO_PUBLIC_*` prefix is intentional: Expo
# inlines these into the JS bundle. Treat the API key as a build-time
# secret with narrow permissions, NOT as a per-user identity. See ADR-009
# for the migration path to per-install device-registered keys.

PULSE_DOMAIN=energy
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
EXPO_PUBLIC_API_KEY=
