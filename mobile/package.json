{
  "name": "pulse-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Pulse white-label mobile shell — Expo SDK 52 + Expo Router. Branding, region defaults, and the API contract come from config/domains/<name>.yaml at build time. See ADR-009.",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint"
  },
  "dependencies": {
    "expo": "52.0.7",
    "expo-constants": "17.0.3",
    "expo-linking": "7.0.3",
    "expo-router": "4.0.6",
    "expo-status-bar": "2.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.2",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "4.1.0",
    "react-native-web": "0.19.13"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/react": "18.3.12",
    "eslint": "9.17.0",
    "eslint-config-expo": "8.0.1",
    "js-yaml": "4.1.0",
    "typescript": "5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
