      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "pulse-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH target AS (\n  SELECT CASE\n    WHEN '$date' = 'today'    THEN CURRENT_DATE\n    WHEN '$date' = 'tomorrow' THEN CURRENT_DATE + INTERVAL '1 day'\n    ELSE '$date'::date\n  END AS d\n)\nSELECT\n  (SELECT interval_start FROM energy_price, target WHERE region_code = '$region' AND (interval_start AT TIME ZONE 'UTC')::date = target.d ORDER BY total_c_kwh DESC LIMIT 1) AS peak_interval,\n  (SELECT total_c_kwh    FROM energy_price, target WHERE region_code = '$region' AND (interval_start AT TIME ZONE 'UTC')::date = target.d ORDER BY total_c_kwh DESC LIMIT 1) AS peak_price_c_kwh,\n  (SELECT total_c_kwh    FROM energy_price, target WHERE region_code = '$region' AND (interval_start AT TIME ZONE 'UTC')::date = target.d ORDER BY total_c_kwh ASC  LIMIT 1) AS off_peak_price_c_kwh",
          "refId": "A",
          "sql": {
            "columns": [],
            "groupBy": [],
            "limit": 50
          }
        }
      ],
      "title": "Peak / off-peak — $region on $date",
      "type": "stat"
    },
