        {
          "datasource": {
            "type": "postgres",
            "uid": "pulse-postgres"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  ((interval_start AT TIME ZONE 'UTC')::date)::timestamptz AS time,\n  MAX(total_c_kwh) AS peak,\n  AVG(total_c_kwh) AS mean,\n  MIN(total_c_kwh) AS off_peak\nFROM energy_price\nWHERE region_code = '$region'\n  AND (interval_start AT TIME ZONE 'UTC')::date >= CURRENT_DATE - INTERVAL '30 days'\nGROUP BY ((interval_start AT TIME ZONE 'UTC')::date)\nORDER BY ((interval_start AT TIME ZONE 'UTC')::date)",
          "refId": "A",
          "sql": {
            "columns": [],
            "groupBy": [],
            "limit": 50
          }
        }
      ],
