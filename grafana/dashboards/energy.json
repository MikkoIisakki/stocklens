      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "pulse-postgres"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  interval_start AS time,\n  total_c_kwh AS \"total c/kWh\"\nFROM energy_price\nWHERE region_code = '$region'\n  AND (interval_start AT TIME ZONE 'UTC')::date = CASE\n    WHEN '$date' = 'today'    THEN CURRENT_DATE\n    WHEN '$date' = 'tomorrow' THEN CURRENT_DATE + INTERVAL '1 day'\n    ELSE '$date'::date\n  END\nORDER BY interval_start",
          "refId": "A",
          "sql": {
            "columns": [],
            "groupBy": [],
            "limit": 50
          }
        }
      ],
      "title": "24h interval prices — $region on $date",
      "type": "timeseries"
    },
