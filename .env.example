# Copy this file to .env and fill in values
# Never commit .env to git

# PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_NAME=stocks
DB_USER=stocks
DB_PASSWORD=changeme
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Application
LOG_LEVEL=INFO
ENVIRONMENT=development
MAX_INGEST_AGE_HOURS=25

# External API keys — obtain from provider dashboards
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
FRED_API_KEY=

# Grafana (local dev only — default admin/admin)
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin
